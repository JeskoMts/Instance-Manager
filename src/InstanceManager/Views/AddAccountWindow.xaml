<Window x:Class="InstanceManager.Views.AddAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Add account" Height="660" Width="520" MinWidth="420" MinHeight="520"
        WindowStartupLocation="CenterOwner" WindowStyle="None"
        Background="{DynamicResource Brush.Window}"
        TextElement.Foreground="{DynamicResource Brush.TextPrimary}"
        TextElement.FontFamily="Segoe UI" TextElement.FontSize="13">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="42" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6"
                                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.SurfaceHover}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="{DynamicResource Brush.Window}">
                <TextBlock Text="Roblox login — add account" VerticalAlignment="Center"
                           Margin="14,0,0,0" FontWeight="SemiBold" />
                <Button Style="{StaticResource CaptionButton}" Content="&#xE8BB;" Click="Cancel_Click"
                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" />
            </Grid>

            <Border Grid.Row="1" Background="{DynamicResource Brush.Surface}" Padding="14,8" Margin="0">
                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12"
                           Text="Sign in to Roblox normally below. Instance Manager then captures the login automatically (stored locally and DPAPI-encrypted) — no passwords are saved." />
            </Border>

            <Grid Grid.Row="2">
                <wv2:WebView2 x:Name="WebView" />
                <Border x:Name="ErrorPanel" Background="{DynamicResource Brush.Window}" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="380">
                        <TextBlock x:Name="ErrorText" TextWrapping="Wrap" TextAlignment="Center"
                                   Foreground="{DynamicResource Brush.TextSecondary}" />
                        <Button x:Name="DownloadRuntimeButton" Style="{StaticResource GhostButton}" Margin="0,12,0,0"
                                HorizontalAlignment="Center" Content="Download WebView2 runtime"
                                Click="DownloadRuntime_Click" Visibility="Collapsed" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="3" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0,1,0,0" Padding="14,10">
                <Grid>
                    <TextBlock x:Name="StatusText" VerticalAlignment="Center" FontSize="12"
                               Foreground="{DynamicResource Brush.TextMuted}" Text="Loading Roblox login…" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource GhostButton}" Content="Cancel" Click="Cancel_Click" Margin="0,0,8,0" />
                        <Button Style="{StaticResource PrimaryButton}" Content="Use this account" Click="Capture_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
