<Window x:Class="InstanceManager.Views.ThemeEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Instance Manager" SizeToContent="Height" Width="480" MaxHeight="760"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="NoResize"
        Background="{DynamicResource Brush.Window}" TextElement.Foreground="{DynamicResource Brush.TextPrimary}"
        TextElement.FontFamily="Segoe UI" TextElement.FontSize="13">
    <shell:WindowChrome.WindowChrome><shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="0" GlassFrameThickness="0" /></shell:WindowChrome.WindowChrome>
    <Border BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1" CornerRadius="10" Background="{DynamicResource Brush.Surface}">
        <DockPanel Margin="20">
            <TextBlock DockPanel.Dock="Top" x:Name="TitleText" Text="New theme" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16" />

            <StackPanel DockPanel.Dock="Bottom">
                <TextBlock x:Name="ErrorText" Foreground="{DynamicResource Brush.Danger}" FontSize="11" Margin="0,10,0,0" Visibility="Collapsed" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Style="{StaticResource GhostButton}" Content="Cancel" IsCancel="True" Click="Cancel_Click" Margin="0,0,8,0" />
                    <Button Style="{StaticResource PrimaryButton}" Content="Save theme" IsDefault="True" Click="Save_Click" />
                </StackPanel>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Name" FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,0,4" />
                    <TextBox x:Name="NameBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,8" />

                    <TextBlock Style="{StaticResource SectionHeader}" Text="APP BACKGROUND" Margin="0,8,0,8" />
                    <Grid x:Name="WindowRow" Margin="0,0,0,7">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Window / App" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" />
                        <Border Grid.Column="1" Width="22" Height="22" CornerRadius="5" Margin="0,0,8,0" BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1" Background="{Binding Text, ElementName=WindowBox, Converter={StaticResource HexToBrush}}" />
                        <TextBox Grid.Column="2" x:Name="WindowBox" Style="{StaticResource ModernTextBox}" Width="104" FontSize="12" />
                    </Grid>
                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Surface" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" />
                        <Border Grid.Column="1" Width="22" Height="22" CornerRadius="5" Margin="0,0,8,0" BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1" Background="{Binding Text, ElementName=SurfaceBox, Converter={StaticResource HexToBrush}}" />
                        <TextBox Grid.Column="2" x:Name="SurfaceBox" Style="{StaticResource ModernTextBox}" Width="104" FontSize="12" />
                    </Grid>
                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Surface hover" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" />
                        <Border Grid.Column="1" Width="22" Height="22" CornerRadius="5" Margin="0,0,8,0" BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1" Background="{Binding Text, ElementName=SurfaceHoverBox, Converter={StaticResource HexToBrush}}" />
                        <TextBox Grid.Column="2" x:Name="SurfaceHoverBox" Style="{StaticResource ModernTextBox}" Width="104" FontSize="12" />
                    </Grid>
                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Surface active" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" />
                        <Border Grid.Column="1" Width="22" Height="22" CornerRadius="5" Margin="0,0,8,0" BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1" Background="{Binding Text, ElementName=SurfaceActiveBox, Converter={StaticResource HexToBrush}}" />
                        <TextBox Grid.Column="2" x:Name="SurfaceActiveBox" Style="{StaticResource ModernTextBox}" Width="104" FontSize="12" />
                    </Grid>
                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Elevated" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" />
                        <Border Grid.Column="1" Width="22" Height="22" CornerRadius="5" Margin="0,0,8,0" BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1" Background="{Binding Text, ElementName=ElevatedBox, Converter={StaticResource HexToBrush}}" />
                        <TextBox Grid.Column="2" x:Name="ElevatedBox" Style="{StaticResource ModernTextBox}" Width="104" FontSize="12" />
                    </Grid>
                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Elevated hover" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" />
                        <Border Grid.Column="1" Width="22" Height="22" CornerRadius="5" Margin="0,0,8,0" BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1" Background="{Binding Text, ElementName=ElevatedHoverBox, Converter={StaticResource HexToBrush}}" />
                        <TextBox Grid.Column="2" x:Name="ElevatedHoverBox" Style="{StaticResource ModernTextBox}" Width="104" FontSize="12" />
                    </Grid>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="TYPOGRAPHY" Margin="0,12,0,8" />
                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Primary text" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" />
                        <Border Grid.Column="1" Width="22" Height="22" CornerRadius="5" Margin="0,0,8,0" BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1" Background="{Binding Text, ElementName=TextPrimaryBox, Converter={StaticResource HexToBrush}}" />
                        <TextBox Grid.Column="2" x:Name="TextPrimaryBox" Style="{StaticResource ModernTextBox}" Width="104" FontSize="12" />
                    </Grid>
                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Secondary text" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" />
                        <Border Grid.Column="1" Width="22" Height="22" CornerRadius="5" Margin="0,0,8,0" BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1" Background="{Binding Text, ElementName=TextSecondaryBox, Converter={StaticResource HexToBrush}}" />
                        <TextBox Grid.Column="2" x:Name="TextSecondaryBox" Style="{StaticResource ModernTextBox}" Width="104" FontSize="12" />
                    </Grid>
                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Muted text" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" />
                        <Border Grid.Column="1" Width="22" Height="22" CornerRadius="5" Margin="0,0,8,0" BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1" Background="{Binding Text, ElementName=TextMutedBox, Converter={StaticResource HexToBrush}}" />
                        <TextBox Grid.Column="2" x:Name="TextMutedBox" Style="{StaticResource ModernTextBox}" Width="104" FontSize="12" />
                    </Grid>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="BORDERS" Margin="0,12,0,8" />
                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Border" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" />
                        <Border Grid.Column="1" Width="22" Height="22" CornerRadius="5" Margin="0,0,8,0" BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1" Background="{Binding Text, ElementName=BorderBox, Converter={StaticResource HexToBrush}}" />
                        <TextBox Grid.Column="2" x:Name="BorderBox" Style="{StaticResource ModernTextBox}" Width="104" FontSize="12" />
                    </Grid>
                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Border strong" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" />
                        <Border Grid.Column="1" Width="22" Height="22" CornerRadius="5" Margin="0,0,8,0" BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1" Background="{Binding Text, ElementName=BorderStrongBox, Converter={StaticResource HexToBrush}}" />
                        <TextBox Grid.Column="2" x:Name="BorderStrongBox" Style="{StaticResource ModernTextBox}" Width="104" FontSize="12" />
                    </Grid>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="ACCENT" Margin="0,12,0,8" />
                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Accent" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" />
                        <Border Grid.Column="1" Width="22" Height="22" CornerRadius="5" Margin="0,0,8,0" BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1" Background="{Binding Text, ElementName=AccentBox, Converter={StaticResource HexToBrush}}" />
                        <TextBox Grid.Column="2" x:Name="AccentBox" Style="{StaticResource ModernTextBox}" Width="104" FontSize="12" />
                    </Grid>
                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="On accent (text)" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" />
                        <Border Grid.Column="1" Width="22" Height="22" CornerRadius="5" Margin="0,0,8,0" BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1" Background="{Binding Text, ElementName=OnAccentBox, Converter={StaticResource HexToBrush}}" />
                        <TextBox Grid.Column="2" x:Name="OnAccentBox" Style="{StaticResource ModernTextBox}" Width="104" FontSize="12" />
                    </Grid>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="STATE" Margin="0,12,0,8" />
                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Success" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" />
                        <Border Grid.Column="1" Width="22" Height="22" CornerRadius="5" Margin="0,0,8,0" BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1" Background="{Binding Text, ElementName=SuccessBox, Converter={StaticResource HexToBrush}}" />
                        <TextBox Grid.Column="2" x:Name="SuccessBox" Style="{StaticResource ModernTextBox}" Width="104" FontSize="12" />
                    </Grid>
                    <Grid Margin="0,0,0,2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Danger / Error" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" />
                        <Border Grid.Column="1" Width="22" Height="22" CornerRadius="5" Margin="0,0,8,0" BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1" Background="{Binding Text, ElementName=DangerBox, Converter={StaticResource HexToBrush}}" />
                        <TextBox Grid.Column="2" x:Name="DangerBox" Style="{StaticResource ModernTextBox}" Width="104" FontSize="12" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
