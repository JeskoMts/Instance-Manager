<Window x:Class="InstanceManager.Views.GroupEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Instance Manager" SizeToContent="Height" Width="440"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="NoResize"
        Background="{DynamicResource Brush.Window}" TextElement.Foreground="{DynamicResource Brush.TextPrimary}"
        TextElement.FontFamily="Segoe UI" TextElement.FontSize="13">
    <shell:WindowChrome.WindowChrome><shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="0" GlassFrameThickness="0" /></shell:WindowChrome.WindowChrome>
    <Border BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1" CornerRadius="10" Background="{DynamicResource Brush.Surface}">
        <StackPanel Margin="20">
            <TextBlock x:Name="TitleText" Text="New group" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16" />
            <TextBlock Text="Name" FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,0,4" />
            <TextBox x:Name="NameBox" Style="{StaticResource ModernTextBox}" />
            <TextBlock Text="Color" FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,14,0,7" />
            <UniformGrid x:Name="ColorGrid" Columns="6">
                <RadioButton GroupName="color" Tag="#D9646C" Checked="Color_Checked" Style="{StaticResource ColorChoice}" Background="#D9646C" />
                <RadioButton GroupName="color" Tag="#D98E5A" Checked="Color_Checked" Style="{StaticResource ColorChoice}" Background="#D98E5A" />
                <RadioButton GroupName="color" Tag="#D9C56A" Checked="Color_Checked" Style="{StaticResource ColorChoice}" Background="#D9C56A" />
                <RadioButton GroupName="color" Tag="#A7C25E" Checked="Color_Checked" Style="{StaticResource ColorChoice}" Background="#A7C25E" />
                <RadioButton GroupName="color" Tag="#6FB08A" Checked="Color_Checked" Style="{StaticResource ColorChoice}" Background="#6FB08A" />
                <RadioButton GroupName="color" Tag="#5BAFA8" Checked="Color_Checked" Style="{StaticResource ColorChoice}" Background="#5BAFA8" />
                <RadioButton GroupName="color" Tag="#5AA6C9" Checked="Color_Checked" Style="{StaticResource ColorChoice}" Background="#5AA6C9" />
                <RadioButton GroupName="color" Tag="#6E8FD9" Checked="Color_Checked" Style="{StaticResource ColorChoice}" Background="#6E8FD9" />
                <RadioButton GroupName="color" Tag="#8A82D9" Checked="Color_Checked" Style="{StaticResource ColorChoice}" Background="#8A82D9" />
                <RadioButton GroupName="color" Tag="#A56FC0" Checked="Color_Checked" Style="{StaticResource ColorChoice}" Background="#A56FC0" />
                <RadioButton GroupName="color" Tag="#CF6FA8" Checked="Color_Checked" Style="{StaticResource ColorChoice}" Background="#CF6FA8" />
                <RadioButton GroupName="color" Tag="#8A8F98" Checked="Color_Checked" Style="{StaticResource ColorChoice}" Background="#8A8F98" />
            </UniformGrid>
            <TextBlock x:Name="ErrorText" Foreground="{DynamicResource Brush.Danger}" FontSize="11" Margin="0,10,0,0" Visibility="Collapsed" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Style="{StaticResource GhostButton}" Content="Cancel" IsCancel="True" Click="Cancel_Click" Margin="0,0,8,0" />
                <Button Style="{StaticResource PrimaryButton}" Content="Save group" IsDefault="True" Click="Save_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
