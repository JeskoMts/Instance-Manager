<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


    <Color x:Key="Color.Window">#0A0A0A</Color>
    <Color x:Key="Color.Surface">#151515</Color>
    <Color x:Key="Color.SurfaceHover">#1E1E1E</Color>
    <Color x:Key="Color.SurfaceActive">#262626</Color>
    <Color x:Key="Color.Elevated">#2D2D2D</Color>
    <Color x:Key="Color.ElevatedHover">#383838</Color>

    <Color x:Key="Color.Border">#2C2C2C</Color>
    <Color x:Key="Color.BorderStrong">#3D3D3D</Color>

    <Color x:Key="Color.Accent">#EDEDED</Color>
    <Color x:Key="Color.OnAccent">#0A0A0A</Color>

    <Color x:Key="Color.TextPrimary">#F2F2F2</Color>
    <Color x:Key="Color.TextSecondary">#B4B4B4</Color>
    <Color x:Key="Color.TextMuted">#8C8C8C</Color>

    <Color x:Key="Color.Success">#5B9E7E</Color>
    <Color x:Key="Color.Danger">#C65F55</Color>

    <SolidColorBrush x:Key="Brush.Window" Color="{StaticResource Color.Window}" />
    <SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.Surface}" />
    <SolidColorBrush x:Key="Brush.SurfaceHover" Color="{StaticResource Color.SurfaceHover}" />
    <SolidColorBrush x:Key="Brush.SurfaceActive" Color="{StaticResource Color.SurfaceActive}" />
    <SolidColorBrush x:Key="Brush.Elevated" Color="{StaticResource Color.Elevated}" />
    <SolidColorBrush x:Key="Brush.ElevatedHover" Color="{StaticResource Color.ElevatedHover}" />

    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Border}" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="{StaticResource Color.BorderStrong}" />

    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.OnAccent" Color="{StaticResource Color.OnAccent}" />

    <SolidColorBrush x:Key="Brush.ButtonPrimary" Color="{StaticResource Color.Elevated}" />
    <SolidColorBrush x:Key="Brush.ButtonPrimaryHover" Color="{StaticResource Color.ElevatedHover}" />
    <SolidColorBrush x:Key="Brush.ButtonPrimaryPressed" Color="{StaticResource Color.SurfaceActive}" />

    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}" />

    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}" />
    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Danger}" />

    <SolidColorBrush x:Key="Brush.Scrim" Color="#000000" Opacity="0.55" />

</ResourceDictionary>
