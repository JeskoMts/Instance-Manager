<Application x:Class="InstanceManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:InstanceManager.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Colors.xaml" />
                <ResourceDictionary Source="Themes/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:StringToBrushConverter x:Key="HexToBrush" />
            <conv:EnumToBooleanConverter x:Key="EnumBool" />
            <conv:EnumToVisibilityConverter x:Key="EnumVis" />
            <conv:InverseBooleanConverter x:Key="InverseBool" />
            <conv:EmptyStringToVisibilityConverter x:Key="EmptyToVis" />
            <conv:EmptyAndUnfocusedToVisibilityConverter x:Key="EmptyUnfocusedToVis" />
            <conv:MillisecondsToSecondsConverter x:Key="MsToSec" />
            <conv:AttemptsToLabelConverter x:Key="AttemptsLabel" />
            <conv:ThemeCardVisibilityConverter x:Key="ThemeCardVis" PrimaryCount="8" />
            <conv:ThemeGridColumnsConverter x:Key="ThemeGridColumns" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
